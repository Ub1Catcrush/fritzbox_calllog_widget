<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Actions first -->

    <!-- Connection -->
    <PreferenceCategory android:title="@string/pref_category_connection" app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="pref_username"
            android:title="@string/pref_username_title"
            android:summary="@string/pref_username_summary"
            android:defaultValue=""
            android:inputType="text"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:key="pref_password"
            android:title="@string/pref_password_title"
            android:summary="@string/pref_password_summary"
            android:defaultValue=""
            android:inputType="textPassword"
            app:iconSpaceReserved="false"/>

        <!-- Opens ConnectionProfilesActivity — sortable LAN / Internet TR-064 / MyFRITZ list -->
        <Preference
            android:key="pref_open_connections"
            android:title="@string/pref_connections_title"
            android:summary="@string/pref_connections_summary"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <!-- Refresh / Data -->
    <PreferenceCategory android:title="@string/pref_category_refresh" app:iconSpaceReserved="false">
        <EditTextPreference android:key="pref_refresh"      android:title="@string/pref_refresh_title"     android:summary="@string/pref_refresh_summary"     android:defaultValue="300" android:inputType="number" app:iconSpaceReserved="false"/>
        <EditTextPreference android:key="pref_max_entries"  android:title="@string/pref_max_entries_title" android:summary="@string/pref_max_entries_summary" android:defaultValue="20"  android:inputType="number" app:iconSpaceReserved="false"/>
        <EditTextPreference android:key="pref_phone_prefix" android:title="@string/pref_prefix_title"     android:summary="@string/pref_prefix_summary"     android:defaultValue=""    android:inputType="phone"  app:iconSpaceReserved="false"/>
    </PreferenceCategory>

    <!-- Display -->
    <PreferenceCategory android:title="@string/pref_category_display" app:iconSpaceReserved="false">
        <ListPreference android:key="pref_language"    android:title="@string/pref_language_title"    android:summary="%s" android:entries="@array/language_entries"    android:entryValues="@array/language_values"    android:defaultValue="system" app:iconSpaceReserved="false"/>
        <ListPreference android:key="pref_theme"       android:title="@string/pref_theme_title"       android:summary="%s" android:entries="@array/theme_entries"       android:entryValues="@array/theme_values"       android:defaultValue="system" app:iconSpaceReserved="false"/>
        <ListPreference android:key="pref_font_family" android:title="@string/pref_font_family_title" android:summary="%s" android:entries="@array/font_family_entries" android:entryValues="@array/font_family_values" android:defaultValue="default" app:iconSpaceReserved="false"/>
        <ListPreference android:key="pref_font_size"   android:title="@string/pref_font_size_title"   android:summary="%s" android:entries="@array/font_size_entries"   android:entryValues="@array/font_size_values"   android:defaultValue="11"     app:iconSpaceReserved="false"/>
    </PreferenceCategory>

    <!-- Light Mode Colors -->
    <PreferenceCategory android:title="@string/pref_category_colors_light" app:iconSpaceReserved="false">
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_header_bg"       android:title="@string/pref_color_header_bg"       app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_header_text"     android:title="@string/pref_color_header_text"     app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_col_header_bg"   android:title="@string/pref_color_col_header_bg"   app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_col_header_text" android:title="@string/pref_color_col_header_text" app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_widget_bg"       android:title="@string/pref_color_widget_bg"       app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_row_even"        android:title="@string/pref_color_row_even"        app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_row_odd"         android:title="@string/pref_color_row_odd"         app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_text_primary"    android:title="@string/pref_color_text_primary"    app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_text_secondary"  android:title="@string/pref_color_text_secondary"  app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_divider"         android:title="@string/pref_color_divider"         app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_error"           android:title="@string/pref_color_error"           app:iconSpaceReserved="false"/>
    </PreferenceCategory>

    <!-- Dark Mode Colors -->
    <PreferenceCategory android:title="@string/pref_category_colors_dark" app:iconSpaceReserved="false">
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_header_bg_dark"       android:title="@string/pref_color_header_bg"       app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_header_text_dark"     android:title="@string/pref_color_header_text"     app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_col_header_bg_dark"   android:title="@string/pref_color_col_header_bg"   app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_col_header_text_dark" android:title="@string/pref_color_col_header_text" app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_widget_bg_dark"       android:title="@string/pref_color_widget_bg"       app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_row_even_dark"        android:title="@string/pref_color_row_even"        app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_row_odd_dark"         android:title="@string/pref_color_row_odd"         app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_text_primary_dark"    android:title="@string/pref_color_text_primary"    app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_text_secondary_dark"  android:title="@string/pref_color_text_secondary"  app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_divider_dark"         android:title="@string/pref_color_divider"         app:iconSpaceReserved="false"/>
        <com.tvcs.fritzboxcallwidget.prefs.ColorPickerPreference android:key="pref_color_error_dark"           android:title="@string/pref_color_error"           app:iconSpaceReserved="false"/>
    </PreferenceCategory>

    <!-- Reset -->
    <PreferenceCategory app:iconSpaceReserved="false">
        <Preference android:key="pref_reset_colors" android:title="@string/pref_reset_colors_title" android:summary="@string/pref_reset_colors_summary" app:iconSpaceReserved="false"/>
    </PreferenceCategory>

</PreferenceScreen>
