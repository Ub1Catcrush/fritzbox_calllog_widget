<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- Drag handle: decorative — not focusable, not in a11y tree -->
    <ImageView
        android:id="@+id/iv_drag_handle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_drag_handle"
        android:padding="2dp"
        android:importantForAccessibility="no"
        android:focusable="false"
        android:contentDescription="@null" />

    <CheckBox
        android:id="@+id/cb_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_profile_host"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <!-- Test icon: use a dedicated "check/diagnose" description -->
    <ImageView
        android:id="@+id/iv_test"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_refresh"
        android:padding="4dp"
        android:contentDescription="@string/test_connection" />

    <!-- Edit settings icon -->
    <ImageView
        android:id="@+id/iv_edit"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_settings"
        android:padding="4dp"
        android:contentDescription="@string/edit_profile" />

</LinearLayout>
