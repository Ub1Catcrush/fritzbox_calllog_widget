<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_fritzcalllog"
        android:roundIcon="@mipmap/ic_fritzcalllog_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FritzBoxCallWidget"
        android:usesCleartextTraffic="true">


        <!-- Invisible trampoline so widget row taps can use an explicit,
             FLAG_MUTABLE PendingIntent on Android 14+ -->
        <activity
            android:name=".widget.DialActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay" />

        <!-- Settings Activity -->
        <activity
            android:name=".prefs.SettingsActivity"
            android:exported="true"
            android:label="@string/settings_title">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget Config Activity -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:label="@string/widget_configure">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- App Widget Provider -->
        <receiver
            android:name=".widget.CallLogWidget"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.tvcs.fritzboxcallwidget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/call_log_widget_info" />
        </receiver>

        <!-- Widget Update Service -->
        <service
            android:name=".widget.WidgetUpdateService"
            android:exported="false" />

        <!-- RemoteViews list service for widget ListView -->
        <service
            android:name=".widget.CallLogRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- Boot receiver to restart periodic updates -->
        <receiver
            android:name=".widget.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
